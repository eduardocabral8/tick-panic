{
  "name": "tick-panic",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A fast-paced, high-pressure real-time multiplayer party game with shrinking time limits.",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "prepare": "husky",
    "lint": "eslint .",
    "dev": "pnpm -r --parallel dev"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.3"
  },
  "packageManager": "pnpm@9.0.0"
}
